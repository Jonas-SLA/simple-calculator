# ─────────────────────────────────────────────
# Environment variables for secure-calculator
# Copy this file to .env and fill in the values
# NEVER commit the real .env file
# ─────────────────────────────────────────────

# App
APP_NAME=secure-calculator
PORT=3000
NODE_ENV=development

# CORS — set to your frontend URL in production (never use * in production)
CORS_ORIGIN=*
